# -----------------------------------------------------------------------------
# Twilio — same values as a working Messages API request:
#
#   curl 'https://api.twilio.com/2010-04-01/Accounts/YOUR_SID/Messages.json' -X POST \
#     --data-urlencode 'To=+91XXXXXXXXXX' \
#     --data-urlencode 'From=+1XXXXXXXXXX' \
#     --data-urlencode 'Body=test' \
#     -u YOUR_SID:YOUR_AUTH_TOKEN
#
# TWILIO_ACCOUNT_SID  → the "AC…" in the URL and before ":" in -u
# TWILIO_AUTH_TOKEN   → the part after ":" in -u
# TWILIO_SMS_FROM     → must equal curl "From=" (E.164 only, no sms: or whatsapp:)
#
# Optional: use a Messaging Service instead of TWILIO_SMS_FROM (starts with MG…)
# TWILIO_MESSAGING_SERVICE_SID=MGxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
#
# Trial Twilio accounts: SMS only works to numbers you verify in the console
# (Phone Numbers → Manage → Verified Caller IDs). Otherwise upgrade and add billing.
# -----------------------------------------------------------------------------
TWILIO_ACCOUNT_SID=ACe123b1097fb4d479dffdd607bdef9582
TWILIO_AUTH_TOKEN=8f84853b0b5e2977b42bc2b009ef736b

# SMS OTP + programmatic SMS (required for signup/login codes unless you use MG… above)
TWILIO_SMS_FROM=+16624904640

# Optional SMS "from" fallback (same E.164 as a Twilio number); see phoneOtp.ts — not used for WhatsApp reminders
# TWILIO_FROM_WHATSAPP=+1xxxxxxxxxx

# WhatsApp reminders + instant confirmation: whatsapp-web.js (link this server’s WhatsApp via QR in the terminal)
WHATSAPP_WEB_ENABLED=false
# Prefer Mongo-backed shared session so deploys/restarts restore the same WhatsApp login.
# Keep this true for hosted backends using the same MongoDB as the app.
WWEBJS_REMOTE_AUTH_ENABLED=true
# Shared RemoteAuth session name. Use the same value anywhere you want to restore the same login.
WWEBJS_SESSION_NAME=medmind-main
# How often RemoteAuth syncs the session back to Mongo (ms)
# WWEBJS_REMOTE_BACKUP_MS=300000
# Optional LocalAuth folder (default: ./.wwebjs_auth under the backend cwd)
# WWEBJS_AUTH_PATH=
